# Data / training
MODEL_EXPERIMENT_DIR=models/output
MODEL_RANDOM_SEED=42
MODEL_SET=all
MISSING_STRATEGY=median
CV_MODE=purged
COST_FP=1.0
COST_FN=5.0

# Data sources
ETL_DB_URL=postgresql+psycopg2://airflow:airflow@postgres:5432/airflow
PUBLIC_BCB_SOURCE=https://api.bcb.gov.br/dados/serie
PUBLIC_CVM_SOURCE=https://dados.cvm.gov.br
NEWS_API_SOURCE=https://gnews.io
SECURITY_FEED_SOURCE=https://services.nvd.nist.gov/rest/json/cves/2.0
OPEN_BANKING_SOURCE=nao_especificado
INTERNAL_SOURCE=nao_especificado

# MLOps
MLFLOW_TRACKING_URI=
DVC_REMOTE=nao_especificado

# Security / API integration
KMS_SECRETS_URI=kms://placeholder/model-secrets
MODEL_EXPORT_FORMAT=onnx
