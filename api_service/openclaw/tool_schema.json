{
  "name": "trust_score_tools",
  "description": "Trust Score API tools for scoring institutions",
  "tools": [
    {
      "name": "trust_score_get",
      "description": "Get trust score and explanation for one institution",
      "input_schema": {
        "type": "object",
        "properties": {
          "institution_id": {
            "type": "string",
            "description": "Institution identifier"
          }
        },
        "required": ["institution_id"],
        "additionalProperties": false
      }
    },
    {
      "name": "trust_score_batch",
      "description": "Score a batch of institutions",
      "input_schema": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "minItems": 1,
            "maxItems": 500,
            "items": {
              "type": "object",
              "properties": {
                "institution_id": { "type": "string" },
                "features": {
                  "type": "object",
                  "additionalProperties": { "type": "number" }
                }
              },
              "required": ["institution_id"],
              "additionalProperties": false
            }
          }
        },
        "required": ["items"],
        "additionalProperties": false
      }
    }
  ]
}
