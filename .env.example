# ===== Global =====
ENVIRONMENT=dev
KMS_KEY_ID=kms-placeholder-dev
KMS_SECRETS_URI=kms://placeholder/local/dev

# ===== S3 / MinIO =====
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_BUCKET=raw-data
S3_PREFIX=raw

# ===== ETL =====
ETL_DB_URL=postgresql+psycopg2://airflow:airflow@pipeline-postgres:5432/airflow
OPEN_BANKING_TOKEN_URL=https://provider.example.com/oauth/token
OPEN_BANKING_CLIENT_ID=replace-me
OPEN_BANKING_CLIENT_SECRET=replace-me
OPEN_BANKING_API_BASE_URL=https://provider.example.com/open-banking
NEWS_API_KEY=replace-me
NEWS_API_URL=https://newsapi.org/v2/everything
CVE_API_BASE_URL=https://services.nvd.nist.gov/rest/json/cves/2.0
FINANCIAL_SOURCE_URL=https://example.com/public/financials

# ===== API Service =====
SERVICE_DB_URL=postgresql+asyncpg://service:service@service-postgres:5432/service
REDIS_URL=redis://redis:6379/0
MODEL_ONNX_PATH=/app/models/model.onnx
MODEL_FEATURES_PATH=/app/models/model_features.json
MODEL_FEATURE_IMPORTANCE_PATH=/app/models/feature_importance.json
JWT_SECRET=change-me-local-only
JWT_ISSUER=trust-score-service
JWT_AUDIENCE=trust-score-clients
RATE_LIMIT_PER_MINUTE=60
CACHE_TTL_SEC=300
ENFORCE_TLS=false
CORS_ORIGINS=http://localhost:8501,http://localhost:3000
AGENT_SIGNING_SECRET=change-me-local-agent
AGENT_ALLOWED_IDS=agent-001
AGENT_SKILL_BLACKLIST=skill-dangerous-001
AGENT_SKILL_ALLOWLIST=trust-score-skill

# ===== Dashboard =====
TRUST_SCORE_URL=http://trust-score-service:8000
DASHBOARD_TRUST_SCORE_TOKEN=
