{
  "title": "Trust Score Service",
  "panels": [
    {
      "title": "Latency (p95)",
      "type": "timeseries",
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(http_request_latency_seconds_bucket[5m])) by (le))"}
      ]
    },
    {
      "title": "Error Rate",
      "type": "timeseries",
      "targets": [
        {"expr": "sum(rate(http_requests_total{status=~'5..'}[5m]))"}
      ]
    },
    {
      "title": "Queue Length",
      "type": "timeseries",
      "targets": [
        {"expr": "max(queue_length)"}
      ]
    },
    {
      "title": "Score Distribution",
      "type": "heatmap",
      "targets": [
        {"expr": "histogram_quantile(0.5, sum(rate(score_value_bucket[5m])) by (le))"}
      ]
    }
  ]
}
